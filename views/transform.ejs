<section class="project-bar">
  <label class="project-name-field">
    name
    <input id="project-name" placeholder="Untitled project">
  </label>
  <span id="project-meta" class="status"></span>
  <a href="/" class="back-link">← all projects</a>
</section>

<section class="step">
  <div class="step-head">
    <span class="step-num">1</span>
    <h2>Source</h2>
    <label class="file-btn">
      <input type="file" id="source-file" accept=".xlsx,.xls">
      <span>Choose xlsx…</span>
    </label>
    <select id="source-sheet" hidden></select>
    <label class="sample-size">
      sample rows:
      <input type="number" id="sample-size" value="10" min="1" max="100">
    </label>
  </div>
  <div id="source-info" class="info"></div>
  <div id="source-grid" class="grid-wrap"></div>
</section>

<section class="step" id="target-step">
  <div class="step-head">
    <span class="step-num">2</span>
    <h2>Destination</h2>
    <label class="file-btn" id="target-file-btn">
      <input type="file" id="target-file" accept=".xlsx,.xls">
      <span>Choose xlsx…</span>
    </label>
    <select id="target-sheet" hidden></select>
    <label class="sample-size">
      header rows:
      <input type="number" id="target-header-rows" value="1" min="1" max="10">
    </label>
    <button id="target-edit-btn" hidden>Edit destination</button>
    <span id="target-locked-note" class="status" hidden>from saved project</span>
  </div>
  <div id="target-info" class="info"></div>
  <div id="target-grid" class="grid-wrap"></div>
</section>

<section class="step">
  <div class="step-head">
    <span class="step-num">3</span>
    <h2>Transformations</h2>
    <button id="propose-btn" disabled>Propose transformations</button>
    <span id="propose-status" class="status"></span>
  </div>
  <div id="transformations"></div>
  <div id="preview-bar" class="preview-bar" hidden>
    <span class="preview-label">Sample preview</span>
    <span id="preview-info" class="status"></span>
  </div>
  <div id="preview-grid" class="grid-wrap"></div>
  <div id="refine-all" class="refine-all" hidden>
    <textarea id="refine-all-comment" placeholder="Overall feedback to refine every transformation (e.g. 'phone numbers should be in E.164 format')"></textarea>
    <button id="refine-all-btn">Refine all</button>
  </div>
</section>

<section class="step">
  <div class="step-head">
    <span class="step-num">4</span>
    <h2>Output</h2>
    <button id="transform-btn" disabled>Transform</button>
    <button id="download-btn" disabled>Download xlsx</button>
    <span id="output-status" class="status"></span>
  </div>
  <div id="output-grid" class="grid-wrap"></div>
</section>

<script>window.__PROJECT_ID__ = <%- JSON.stringify(projectId) %>;</script>
