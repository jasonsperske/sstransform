<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title><%= title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/styles.css">
  <script>
    window.__currentUser = <%- JSON.stringify(safeCurrentUser(currentUser)) %>;
  </script>
  <% if (typeof headScripts !== 'undefined') { headScripts.forEach(function(src) { %>
    <script src="<%= src %>"></script>
  <% }) } %>
  <% if (ga) { %>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%= ga %>"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', '<%= ga %>');
    </script>
  <% } %>
</head>
<body>
  <header>
    <div class="header-main">
      <a class="home-link" href="/"><h1>Spreadsheet Transform</h1></a>
      <div class="subtitle"><%= subtitle %></div>
    </div>
    <% if (authEnabled) { %>
      <div class="auth-controls">
        <% if (currentUser) { %>
          <div class="auth-user">
            <% if (currentUser.picture) { %>
              <img class="auth-avatar" src="<%= currentUser.picture %>" alt="">
            <% } %>
            <span class="auth-name"><%= currentUser.name || currentUser.email || 'Signed in' %></span>
            <form method="post" action="/auth/logout" class="auth-logout">
              <button type="submit">Sign out</button>
            </form>
          </div>
        <% } else { %>
          <div class="auth-signin">
            <span class="auth-signin-label">Sign in:</span>
            <% providers.forEach(function(p) { %>
              <a class="auth-provider-btn" href="/auth/<%= p.id %>"><%= p.label %></a>
            <% }) %>
          </div>
        <% } %>
      </div>
    <% } %>
  </header>
  <main>
    <%- body %>
  </main>
  <% if (typeof bodyScripts !== 'undefined') { bodyScripts.forEach(function(src) { %>
    <script src="<%= src %>"></script>
  <% }) } %>
</body>
</html>
