<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title><%= title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/styles.css">
  <script>
    window.__currentUser = <%- JSON.stringify(safeCurrentUser(currentUser)) %>;
  </script>
  <% if (typeof headScripts !== 'undefined') { headScripts.forEach(function(src) { %>
    <script src="<%= src %>"></script>
  <% }) } %>
  <% if (ga) { %>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%= ga %>"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', '<%= ga %>');
    </script>
  <% } %>
</head>
<body>
  <header>
    <div class="header-main">
      <a class="home-link" href="/"><h1>Spreadsheet Transform</h1></a>
      <div class="subtitle"><%= subtitle %></div>
    </div>
    <% if (authEnabled) { %>
      <div class="auth-controls">
        <% if (currentUser) { %>
          <div class="auth-user" id="auth-user">
            <button type="button" class="auth-user-btn" id="auth-user-btn" aria-haspopup="menu" aria-expanded="false">
              <% if (currentUser.picture) { %>
                <img class="auth-avatar" src="<%= currentUser.picture %>" alt="">
              <% } %>
              <span class="auth-name"><%= currentUser.name || currentUser.email || 'Signed in' %></span>
              <span class="auth-caret" aria-hidden="true">▾</span>
            </button>
            <div class="auth-menu menu" id="auth-menu" role="menu" hidden>
              <a href="/settings" role="menuitem">Settings</a>
              <% if (stripeEnabled) { %>
                <a href="/settings#billing" role="menuitem" id="auth-menu-billing">
                  <span>Billing</span>
                  <span class="auth-menu-balance" id="auth-menu-balance" hidden></span>
                </a>
              <% } %>
              <form method="post" action="/auth/logout" class="auth-logout" role="none">
                <button type="submit" role="menuitem">Sign out</button>
              </form>
            </div>
          </div>
        <% } else { %>
          <div class="auth-signin">
            <span class="auth-signin-label">Sign in:</span>
            <% providers.forEach(function(p) { %>
              <a class="auth-provider-btn" href="/auth/<%= p.id %>"><%= p.label %></a>
            <% }) %>
          </div>
        <% } %>
      </div>
    <% } %>
  </header>
  <main>
    <%- body %>
  </main>
  <% if (currentUser) { %>
    <script>
      (function() {
        var btn = document.getElementById('auth-user-btn');
        var menu = document.getElementById('auth-menu');
        if (!btn || !menu) return;
        var balanceEl = document.getElementById('auth-menu-balance');
        var balanceLoaded = false;
        function fmtTokens(n) {
          if (n >= 1e6) return (n / 1e6).toFixed(n >= 1e7 ? 0 : 1) + 'M';
          if (n >= 1e3) return (n / 1e3).toFixed(n >= 1e4 ? 0 : 1) + 'K';
          return String(n);
        }
        function loadBalance() {
          if (!balanceEl || balanceLoaded) return;
          balanceLoaded = true;
          fetch('/api/billing/status', { credentials: 'same-origin' })
            .then(function(r) { return r.ok ? r.json() : null; })
            .then(function(d) {
              if (!d) return;
              balanceEl.textContent = fmtTokens(d.tokenBalance || 0) + ' tokens';
              balanceEl.hidden = false;
            })
            .catch(function() { balanceLoaded = false; });
        }
        function close() { menu.hidden = true; btn.setAttribute('aria-expanded', 'false'); }
        function open()  { menu.hidden = false; btn.setAttribute('aria-expanded', 'true'); loadBalance(); }
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          menu.hidden ? open() : close();
        });
        document.addEventListener('click', function(e) {
          if (!menu.hidden && !menu.contains(e.target) && e.target !== btn) close();
        });
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && !menu.hidden) close();
        });
      })();
    </script>
  <% } %>
  <% if (typeof bodyScripts !== 'undefined') { bodyScripts.forEach(function(src) { %>
    <script src="<%= src %>"></script>
  <% }) } %>
</body>
</html>
