ANTHROPIC_API_KEY=your-api-key-here
PORT=3000

# ----- Federated login (optional) -----
# Set both the CLIENT_ID and CLIENT_SECRET for a provider to enable it.
# Leave both blank to hide that provider's Sign in button.
# Leave all blank to hide login entirely — the app still runs, all
# sessions are anonymous.

# Google Identity Platform
# https://console.cloud.google.com/ → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: <your base URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft (Azure AD / personal accounts)
# https://entra.microsoft.com/ → App registrations → New registration
# Redirect URI: <your base URL>/auth/microsoft/callback
# MICROSOFT_TENANT controls which accounts can sign in:
#   common    — work/school + personal (default)
#   organizations — work/school only
#   consumers — personal only
#   <tenant-id> — a specific tenant
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# Optional. If unset, the redirect URI is derived from the incoming
# request's host. Set this when the app sits behind a reverse proxy or
# load balancer whose public origin differs from the server's.
# OAUTH_REDIRECT_BASE=https://example.com

# Optional. HMAC secret used to sign session cookies. If unset, a random
# 32-byte secret is generated on first boot and stored at
# data/.session-secret so restarts don't invalidate existing sessions.
# SESSION_SECRET=

# Optional. SQLite file path. Defaults to data/sstransform.sqlite.
# DATABASE_PATH=

# Optional. Google Analytics measurement id.
# GA=
